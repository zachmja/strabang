# Strava API application credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Public base URL where this app is reachable.
# Local dev: use a tunnel (e.g. ngrok) so Strava can reach your webhook.
BASE_URL=http://localhost:3000
PORT=3000

# OAuth scopes. activity:write is required to rename activities.
STRAVA_SCOPE=activity:read_all,activity:write

# Arbitrary string echoed back during the webhook subscription handshake.
STRAVA_WEBHOOK_VERIFY_TOKEN=strabang

# Optional: if set, the webhook lives at /webhook/<secret> instead of /webhook.
# Strava doesn't sign event POSTs, so a random secret path segment keeps
# casual scanners from forging events. Generate with e.g. `openssl rand -hex 16`.
# WEBHOOK_PATH_SECRET=

# Where athlete tokens are persisted.
TOKEN_STORE_PATH=data/tokens.json

# Rename every new activity (true) or only Strava's default titles like
# "Morning Run" (false, default).
RENAME_ALL=false
